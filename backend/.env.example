# MongoDB Configuration
# For Local MongoDB:
MONGODB_URI=mongodb://localhost:27017/lankaBus

# For MongoDB Atlas (Cloud):
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/lankaBus

# Server Configuration
PORT=5000
NODE_ENV=development

# JWT Configuration
JWT_SECRET=your_secret_key_here_change_in_production
JWT_EXPIRE=7d

# CORS Configuration
# Development (open):
# CORS_ORIGIN=*
# Production (required allowlist, comma-separated, no wildcard):
# CORS_ORIGIN=https://app.yourdomain.com,https://admin.yourdomain.com
CORS_ORIGIN=*

# MongoDB Atlas network access reminder for production:
# Allow only your backend server egress IP(s) in Atlas Network Access.
# Do NOT keep 0.0.0.0/0 enabled permanently.

# Supabase Configuration (for fare and stations endpoints)
SUPABASE_URL=
SUPABASE_ANON_KEY=

# App Configuration
APP_NAME=Lanka Bus API
APP_VERSION=1.0.0

# Phone Verification Configuration
REQUIRE_PHONE_OTP_VERIFICATION=true

# Firebase Admin (backend phone token verification)
# Default lookup path: backend/serviceAccountKey.json
# FIREBASE_SERVICE_ACCOUNT_PATH=backend/serviceAccountKey.json
